        <mxCell id="Z9Lno9GwT2kxShbwIgkP-5" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Напрыклад, бацькі ніколі не размаўляў на гэтую тэму з грамадзянінам." vertex="1">
          <mxGeometry height="80" width="320" x="7770" y="600" as="geometry" />
        </mxCell>
        <mxCell id="Z9Lno9GwT2kxShbwIgkP-6" edge="1" parent="1" source="Z9Lno9GwT2kxShbwIgkP-5" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="E6Pdcet48CIMthdxIpfv-12" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="8280" y="280" as="sourcePoint" />
            <mxPoint x="8090" y="730" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Z9Lno9GwT2kxShbwIgkP-7" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін не шукаў вядомую іншым людзям інфармацыю на гэту тэму.&lt;br&gt;&lt;br&gt;Калі чалавек не ведае пра рэальнасць факт &lt;b&gt;A&lt;/b&gt;, то ён не заўважае адсутнасці сваіх ведаў пакуль не сутыкнецца з нейкай з&#39;явай, якую не можа растлумачыць. І таму ў яго няма нагоды спытаць пра факт &lt;b&gt;А&lt;/b&gt; ў іншых людзей. І нават калі чалавек заўважыў, што ён нечага не ведае, то ён, магчыма ўсё роўна не спытаецца. Таму што ўсё ведаць фізічна не магчыма і патрэбна выбіраць пра што даведвацца, а пра што не даведвацца." vertex="1">
          <mxGeometry height="320" width="320" x="6240" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="Z9Lno9GwT2kxShbwIgkP-8" edge="1" parent="1" source="Z9Lno9GwT2kxShbwIgkP-7" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="efOgcQIudSeZyejpRAUV-11" value="">
