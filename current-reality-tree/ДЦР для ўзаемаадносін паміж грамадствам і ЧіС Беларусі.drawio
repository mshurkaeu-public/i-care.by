        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="Гэта абавязковыя патрабаванні. Інакш атрымаецца, што чалавек спрабуе змяніць рэальнасць. А тады ён не можа знаходзіцца ў гэтай частцы схемы/мапы рэальнасці." vertex="1">
          <mxGeometry height="160" width="240" x="10760" y="12400" as="geometry" />
        </mxCell>
        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-4" edge="1" parent="1" source="ZyTAt2VtFQ74LP9XS2Cz-3" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" target="ZyTAt2VtFQ74LP9XS2Cz-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="12500" y="11910" as="sourcePoint" />
