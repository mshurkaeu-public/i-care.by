        <mxCell id="3dHqjCJmRoSQpxOP2cQP-13" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Чалавек мае ўласны жыццёвы досвед, які падказвае чалавеку, што вядомымі яму спосабамі наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt; у яго не атрымаецца." vertex="1">
          <mxGeometry height="120" width="320" x="11640" y="14080" as="geometry" />
        </mxCell>
        <mxCell id="3dHqjCJmRoSQpxOP2cQP-14" edge="1" parent="1" source="3dHqjCJmRoSQpxOP2cQP-13" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;edgeStyle=orthogonalEdgeStyle;curved=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="iWuIWHLo7qSUogTee789-11" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="11610" y="13970" as="sourcePoint" />
