        <mxCell id="DYvX6vR9icD-8CRXjMKn-5" parent="1" style="swimlane;whiteSpace=wrap;html=1;rounded=1;shadow=0;glass=0;fillStyle=hatch;strokeColor=#B3B3B3;align=center;verticalAlign=top;spacing=2;swimlaneFillColor=#E6E6E6;fontFamily=Helvetica;fontSize=14;fontColor=default;fontStyle=0;fillColor=#E6E6E6;swimlaneLine=0;" value="Усе (&lt;font color=&quot;#ff0000&quot;&gt;? усе ?&lt;/font&gt;) магчымыя варыянты грамадзяніну мець патрабаванне да ЧіС у склаўшыхся абставінах." vertex="1">
          <mxGeometry height="240" width="1120" x="-3080" y="2160" as="geometry" />
        </mxCell>
        <mxCell id="DYvX6vR9icD-8CRXjMKn-1" parent="DYvX6vR9icD-8CRXjMKn-5" style="text;html=1;strokeColor=default;fillColor=default;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;flipH=1;fontColor=#FF0000;" value="У грамадзяніна ўзнікае нейкае пажаданне/патрабаванне да ЧіС, якое ўяўляецца вядучым да прывабных вынікаў. Іншымі словамі, у гэты момант грамадзянін сутыкаецца з неабходнасцю таго, каб ЧіС выканалі яго волю для дасягнення прывабных вынікаў." vertex="1">
          <mxGeometry height="160" width="320" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="amg76jyvHcLyriArkF44-4" edge="1" parent="DYvX6vR9icD-8CRXjMKn-5" source="amg76jyvHcLyriArkF44-3" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="DYvX6vR9icD-8CRXjMKn-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="210" y="430" as="sourcePoint" />
            <mxPoint x="680" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="amg76jyvHcLyriArkF44-3" parent="DYvX6vR9icD-8CRXjMKn-5" style="text;html=1;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;rotation=0;fontStyle=0;glass=0;shadow=0;dashed=1;arcSize=7;" value="Для прастаты фармулёвак тут і далей замест доўгай фразы &quot;вядучым да прывабных &lt;u&gt;вынікаў ці працэсаў&lt;/u&gt;&quot; буду выкарыстоўваць больш кароткую &quot;вядучым да прывабных &lt;u&gt;вынікаў&lt;/u&gt;&quot;." vertex="1">
          <mxGeometry height="160" width="200" x="440" y="40" as="geometry" />
        </mxCell>
        <mxCell id="DYvX6vR9icD-8CRXjMKn-2" parent="DYvX6vR9icD-8CRXjMKn-5" style="text;html=1;strokeColor=default;fillColor=default;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;flipH=1;fontColor=#FF0000;" value="У грамадзяніна не ўзнікае ніякага пажадання/патрабавання да ЧіС." vertex="1">
