          </mxGeometry>
        </mxCell>
        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-6" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="У чалавека ёсць адчуванне патэнцыйнай выгады для сябе ад выканання дзеяння &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="11640" y="10440" as="geometry" />
        </mxCell>
        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="На гэтым ДЦР мяне цікавяць галінкі пра тое, чаму людзі &quot;не ведаюць&quot;, &quot;не маюць матывацыі&quot;, &quot;не робяць&quot;.&lt;br&gt;&lt;br&gt;Калі жыццё будзе ісці не па гэтых галінках, то, відавочна, яно будзе ісці па галінках&amp;nbsp;&quot;ведаюць&quot;, &quot;маюць матывацыю&quot;, &quot;робяць&quot;.&lt;br&gt;&lt;br&gt;Пакуль што не бачу сэнсу для сябе разглядаць гэтую галінку глыбей." vertex="1">
          <mxGeometry height="200" width="320" x="11640" y="10160" as="geometry" />
        </mxCell>
        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-8" edge="1" parent="1" source="ZyTAt2VtFQ74LP9XS2Cz-7" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="ZyTAt2VtFQ74LP9XS2Cz-6" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="11570" y="10370" as="sourcePoint" />
            <mxPoint x="11750" y="10400" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ZyTAt2VtFQ74LP9XS2Cz-9" edge="1" parent="1" source="ZyTAt2VtFQ74LP9XS2Cz-6" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;edgeStyle=orthogonalEdgeStyle;curved=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="GzLxldtcCoBzBcEFoExZ-6" value="">
