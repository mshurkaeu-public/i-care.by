            <mxPoint x="9370" y="14170" as="sourcePoint" />
            <mxPoint x="9170" y="14410" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="7yOMyOzH25ERY1u7nGPe-5" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="9160" y="14340" as="geometry" />
        </mxCell>
        <mxCell id="RiQsHyh7R-lcRaABuixa-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="Гэта абавязковае патрабаванне. Бо калі чалавек разглядае (або спрабуе) нейкія спосабы паспрабаваць змяніць рэальнасць, каб наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;, то ён спрабуе такім чынам разабрацца з перашкодай тыпу &quot;чалавек не ведае як наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;&quot;. А значыць, ён знаходзіцца ў частцы рэальнасці &quot;чалавек спрабуе змяніць рэальнасць, каб наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;&quot;. А значыць, не можа знаходзіцца ў гэтай частцы рэальнасці." vertex="1">
          <mxGeometry height="280" width="320" x="9360" y="13760" as="geometry" />
        </mxCell>
        <mxCell id="RiQsHyh7R-lcRaABuixa-4" edge="1" parent="1" source="RiQsHyh7R-lcRaABuixa-3" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="7yOMyOzH25ERY1u7nGPe-2" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="9220" y="10820" as="sourcePoint" />
            <mxPoint x="9410" y="14140" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="T9HF5IEqoSEHh17n0GO--1" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;strokeColor=#0000CC;fontColor=#0000CC;fontStyle=1;" value="2" vertex="1">
          <mxGeometry height="30" width="30" x="6265" y="4325" as="geometry" />
        </mxCell>
        <mxCell id="T9HF5IEqoSEHh17n0GO--2" edge="1" parent="1" source="T9HF5IEqoSEHh17n0GO--1" style="endArrow=classic;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="H2adwTTagYGTjLZC20fY-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="6245" y="2251" as="sourcePoint" />
            <mxPoint x="5000" y="3980" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="T9HF5IEqoSEHh17n0GO--3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=top;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;container=1;dropTarget=1;recursiveResize=0;" value="&lt;div align=&quot;center&quot;&gt;У &lt;font style=&quot;font-size: 20px;&quot; color=&quot;#0000ff&quot;&gt;➁&lt;/font&gt; апішу ўсе магчымыя прычыны, чаму чалавек не мае матывацыі рабіць дзеянне &lt;i&gt;D&lt;/i&gt;. То-бок апішу агульны выпадак.&lt;br&gt;&lt;/div&gt; &lt;br&gt;Сітуацыя такая: чалавек ведае, што можна/патрэбна рабіць дзеянне &lt;i&gt;D&lt;/i&gt;, але не мае матывацыі рабіць дзеянне &lt;i&gt;D&lt;/i&gt;.&lt;br&gt;&lt;br&gt;Адсутнасць матывацыі для выканання дзеяння &lt;i&gt;D&lt;/i&gt; можна апісаць так: &lt;font color=&quot;#0000ff&quot;&gt;[выніковая ўяўляемая прывабнасць выканання дзеяння &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; недастаткова высока для чалавека над &lt;font color=&quot;#ff0000&quot;&gt;[выніковай уяўляемай прывабнасцю &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; для таго, каб чалавек пачаў спрабаваць выканаць дзеянне &lt;i&gt;D&lt;/i&gt;. (У тым ліку, можа быць ніжэй прывабнасці &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання.)&lt;br&gt;&lt;br&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; ⬇️ 1. Сітуацыя &quot;прывабнасць выканання вышэй, але недастаткова&quot;. ⬇️&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; ⬇️ 2. Сітуацыя &quot;прывабнасць выканання ніжэй&quot;. ⬇️&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;Для таго каб мець больш кароткае апісанне сутнасці з&#39;явы, дадаткова запішу &quot;формулу&quot; для сілы матывацыі выканаць дзеянне &lt;i&gt;D&lt;/i&gt;:&lt;br&gt;&lt;br&gt;F&lt;sub&gt;motivationDo&lt;/sub&gt; = &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; ⨪ &lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; ⨪ &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;Сіла матывацыі выканаць дзеянне F&lt;sub&gt;motivationDo&lt;/sub&gt; раўняецца &lt;font color=&quot;#0000ff&quot;&gt;[выніковая уяўляемая прывабнасць выканаць дзеянне &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; мінус &lt;font color=&quot;#ff0000&quot;&gt;[выніковая ўяўляемая прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; і мінус &lt;font color=&quot;#006600&quot;&gt;&quot;дадатковы запас бяспечнасці&quot;&lt;/font&gt; &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt;.&lt;br&gt;&lt;br&gt;Тлумачэнне азначэнняў:&lt;br&gt;F&lt;sub&gt;motivationDo&lt;/sub&gt; — Force of motivation to do (perform action &lt;i&gt;D&lt;/i&gt;).&lt;br&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; — &lt;b&gt;Imaginary&lt;/b&gt; attractiveness of &quot;do&quot; (performing of action &lt;i&gt;D&lt;/i&gt;).&lt;br&gt;&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; — &lt;b&gt;Imaginary&lt;/b&gt; attractiveness of &quot;don&#39;t&quot; (not performing of action &lt;i&gt;D&lt;/i&gt;).&lt;br&gt;&lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; — Extra safety.&lt;br&gt;&lt;br&gt;Я выкарыстоўваю ў &quot;формуле&quot; ⨪ (мінус з кропкай пад ім), каб падкрэсліць, што па сутнасці там павінна быць нешта падобнае да аднімання, але дакладная формула мне невядома. Напрыклад, можа там павінны быць нейкія каэфіцыенты. 🤷&lt;br&gt;&lt;br&gt;Я выкарыстоўваю скарачэнне attr замест цэлага слова attractiveness (прывабнасць), каб формула была крыху карацей на экране.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; мне патрэбна, каб апісаць больш агульны выпадак. Дзве ўяўляемыя прывабнасці неабавязкова параўноўваюцца непасрэдна адна з адной. Напрыклад, калі чалавек ніколі не рабіў дзеянне &lt;i&gt;D&lt;/i&gt;, а тым больш, калі ён ніколі не бачыў, каб дзеянне &lt;i&gt;D&lt;/i&gt; рабілі іншыя, то чалавек можа мець дадатковы &quot;парог&quot;, — &quot;Неяк жа я жыў раней без гэтага?! А тут нейкае новае дзеянне… Халера яго ведае, чым скончыцца гэты эксперымент над жывым чалавекам!&quot; Таксама я думаю, што &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; залежыць ад узроста чалавека. Напрыклад, я зараз з жахам азіраюся на некаторыя рэчы, якія я рабіў, калі быў падлеткам. І мне падаецца вельмі трапным выказванне &quot;мужчына — гэта выпадкова выжыўшы хлопчык&quot;. І думаю, што &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; можа быць негатыўнай у нейкія моманты жыцця чалавека. Напрыклад, чалавек у адчаі пачынае амаль цалкам ігнараваць сваю бяспеку і пачынае спрабаваць любыя варыянты. Магчыма, з думкай, — &quot;Лепей рабіць хоць нешта, чым зусім нічога!&quot;&lt;br&gt;&lt;br&gt;Калі F&lt;sub&gt;motivationDo&lt;/sub&gt; больш нуля, то чалавек імкнецца выканаць дзеянне &lt;i&gt;D&lt;/i&gt; (мае матывацыю выканаць дзеянне). Калі F&lt;sub&gt;motiovationDo&lt;/sub&gt; меней нуля, то чалавек імкнецца не выконваць дзеянне &lt;i&gt;D&lt;/i&gt; (не мае матывацыі выканаць дзеянне). Калі&amp;nbsp;F&lt;sub&gt;motivationDo&lt;/sub&gt; дакладна нуль, то, напэўна, вынік вырашаецца першым выпадковым здарэннем. 🤷&lt;br&gt;&lt;br&gt;&lt;b&gt;Цікавае назіранне&lt;/b&gt; пра розніцу паміж &quot;ідэальнай мадэллю&quot; і &quot;сапраўдным жыццём&quot;:&lt;br&gt;18 студзеня 2025 года ў мяне было ўяўленне (гіпотэза), што&amp;nbsp;&lt;font color=&quot;#ff0000&quot;&gt;[выніковая ўяўляемая прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; раўняецца &lt;b&gt;мінус&lt;/b&gt; &lt;font color=&quot;#ff0000&quot;&gt;[выніковая ўяўляемая &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;прывабнасць выканання дзеяння &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;notAttrDo&lt;/sub&gt;&lt;/font&gt;. (Таксама, калі выкарыстоўваць тую ж логіку, то&amp;nbsp;&lt;font color=&quot;#0000ff&quot;&gt;[выніковая уяўляемая прывабнасць выканаць дзеянне &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; павінна была б раўняцца &lt;b&gt;мінус&lt;/b&gt;&amp;nbsp;&lt;font color=&quot;#0000ff&quot;&gt;[выніковая уяўляемая &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеянне &lt;i&gt;D&lt;/i&gt;]&lt;/font&gt; &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;notAttrDon&#39;t&lt;/sub&gt;&lt;/font&gt;.) Але разумовы эксперымент паказаў, што гэтае ўяўленне/гіпотэза не адпавядае рэальнасці. Зараз апішу сутнасць эксперымента і свае высновы з яго.&lt;br&gt;Разумовы эксперымент:&lt;br&gt;Я ўявіў, што збіраюся зрабіць дзеянне &lt;i&gt;D&lt;/i&gt; — &quot;схадзіць на штодзённы шпацыр&quot;.&lt;br&gt;Мой уяўляемы спіс прывабных наступстваў ад выканання дзеяння быў: 1) карысна для здароўя — +10 &quot;папугаяў&quot;, 2) можна знайсці манетку — +1 &quot;папугай&quot;. ( (+10) + (+1) ) = +11 &quot;папугаяў&quot;.&lt;br&gt;A ўяўляемы спіс &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;прывабных наступстваў ад выканання дзеяння пусты. То-бок -0 &quot;папугаяў&quot;.&lt;br&gt;&lt;font color=&quot;#006600&quot;&gt;&quot;Дадатковы запас бяспечнасці&quot;&lt;/font&gt; &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; быў мне не патрэбны для гэтага дзеяння, бо я ўжо шмат разоў паспяхова рабіў такое дзеянне.&lt;br&gt;І вось самае цікавае, што калі я спытаў сябе, — &quot;А якая ўяўляемая прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння?&quot; — то першае, што прыйшло ў галаву: 1) гэта парушыць маю звычку, якая мне падабаецца. Прывабнасць — -15 &quot;папугаяў&quot;. Я потым паразважаў, што -15 неяк надта моцна, але -5 &quot;папугаяў&quot;&amp;nbsp; дакладна будзе. У любым выпадку, у той дзень уяўляемая прывабнасць невыканання дзеяння для мяне была на адрэзке [-15; -5].&lt;br&gt;Праз азначэнні:&lt;br&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; = +11 &quot;папугаяў&quot;&lt;br&gt;&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; недзе паміж -15 і -5 &quot;папугаямі&quot;&lt;br&gt;&lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; = 0 &quot;папугаяў&quot;&lt;br&gt;&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;notAttrDo&lt;/sub&gt;&lt;/font&gt; = -0 &quot;папугаяў&quot;&lt;br&gt;&lt;br&gt;З гэтага эксперымента бачна, што&amp;nbsp;&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; ≠ -&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;notAttrDo&lt;/sub&gt;&lt;/font&gt;. Маё ўяўленне/гіпотэза было няправільным.&lt;br&gt;Гіпотэза пра тое, што яшчэ паказаў эксперымент пра рэальнасць: Думаю, што ў любога чалавека нервовая сетка працуе праз асацыяцыі. І проста ў маёй нервовай сетцы ўзніклі даволі розныя асацыяцыі ў адказ на пытанне пра ўяўляемую &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;прывабнасць выканання таго дзеяння (&quot;пусты спіс&quot;) і на пытанне пра ўяўляемую прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння (&quot;не-не-не, паламаецца звычка&quot;).&lt;br&gt;&lt;br&gt;Гэты эксперымент не азначае, што немагчыма пабудаваць карысную мадэль. Але паказвае, што праверка мадэлі/гіпотэзы на практыцы дапамагае знайсці яўныя ці няяўныя памылачныя дапушчэнні. Ніхто з людзей не ведае, як на самой справе ўладкавана рэальнасць. Таму мы робім спробы, памыляемся, працуем над знойдзенымі памылкамі і… зноў спрабуем. 👨‍🔬 👩‍🔬&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;З апісанага вышэй эксперымента можна прыйсці да гіпотэзы, што ў кожнага чалавека ў кожны момант і наконт кожнага канкрэтнага дзеяння можа здарыцца свая, магчыма ўнікальная, рэалізацыя алгарытма параўнання прывабнасці выканання і прывабнасці невыканання дзеяння &lt;i&gt;D&lt;/i&gt;. Думаю, сутнасць працэса заўсёды можна апісаць формулай выгляду F&lt;sub&gt;motivationDo&lt;/sub&gt; = &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; ⨪ &lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; ⨪ &lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt;. Але што дакладна выкарыстае нервовае сетка таго чаловека ў тых абставінах — думаю, няма сэнсу спрабаваць угадаць. Нават падазраю, што переважная большасць беларусаў на сённяшні дзень не змогуць апісаць свой уласны працэс фармавання ўласнай сілы матывацыі выканаць канкрэтнае дзеянне &lt;i&gt;D&lt;/i&gt;. Таму далейшы аналіз прычын адсутнасці матывацыі патрэбна зрабіць без дапушчэнняў пра тое, як працуе нервовая сетка чалавека ў дробных дэталях. Замест гэтага патрэбны пошук агульных шаблонаў, якія не залежаць ад дэталяў.&lt;/div&gt;&lt;br&gt;&lt;b&gt;Цікавае назіранне&lt;/b&gt;: гэтая &quot;формула&quot; між іншым тлумачыць, чаму ў чалавека няма матывацыі выканаць тое дзеянне, пра якое ён увогуле не ведае. Для дзеяння, якое чалавек не ведае, уяўляемая прывабнасць выканання проста адсутнічае (? нуль ?). Як і ўяўляемая прывабнасць невыканання. Таму няма &quot;розніцы патэнцыялаў&quot;. Таму не ствараецца &quot;вектар руху&quot; ў бок выканання гэтага невядомага дзеяння. А вось калі&amp;nbsp;&lt;font color=&quot;#006600&quot;&gt;E&lt;sub&gt;safety&lt;/sub&gt;&lt;/font&gt; па нейкай прычыне меней нуля, то, магчыма, нешта будзе адбывацца. 🤷&lt;br&gt;&lt;br&gt;&lt;b&gt;Цікавае назіранне&lt;/b&gt;: гэтая &quot;формула&quot; таксама тлумачыць, чаму ў чалавека ўзнікае матывацыя выканаць дзеянне пад прымусам. Напрыклад, чалавеку не падабаецца ідэя аддаваць значны адсотак ад свайго заробка некаму іншаму (&lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; &amp;lt; 0, то-бок &lt;font color=&quot;#0000ff&quot;&gt;[выніковая уяўляемая прывабнасць выканаць дзеянне]&lt;/font&gt; меней нуля). Але калі гэтага чалавека &quot;ветліва пераконваюць&quot; у неабходнасці аддаць адсотак заробка ўзброеныя людзі, то &lt;font color=&quot;#ff0000&quot;&gt;[выніковая уяўляемая прывабнасць &lt;b&gt;&lt;u&gt;не&lt;/u&gt;&lt;/b&gt;выканання дзеяння]&lt;/font&gt; значна меней нуля (&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; ≪ 0) і можа быць нават меней за &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt; (&lt;font color=&quot;#ff0000&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDon&#39;t&lt;/sub&gt;&lt;/font&gt; &amp;lt; &lt;font color=&quot;#0000ff&quot;&gt;&lt;font face=&quot;Tahoma&quot;&gt;I&lt;/font&gt;&lt;sub&gt;attrDo&lt;/sub&gt;&lt;/font&gt;). А тады па &quot;формуле&quot; ад першага адмоўнага ліка аднімаецца &quot;яшчэ больш адмоўны&quot; другі лік і ўзнікае дадатны вынік. То-бок узнікае матывацыя выканаць дзеянне (аддаць адсотак заробка)." vertex="1">
          <mxGeometry height="2080" width="1120" x="5080" y="2200" as="geometry" />
        </mxCell>
        <mxCell id="I5rNS8t5U8sGtOzm36OQ-18" parent="T9HF5IEqoSEHh17n0GO--3" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontColor=#0000FF;" value="[выніковая ўяўляемая прывабнасць&lt;br&gt;&amp;nbsp;выканання дзеяння &lt;i&gt;D&lt;/i&gt;]" vertex="1">
