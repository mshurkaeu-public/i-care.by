        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-8" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="або" vertex="1">
          <mxGeometry height="30" width="60" x="-2560" y="7350" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-13" parent="1" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;verticalAlign=top;fillColor=#E6E6E6;strokeColor=#B3B3B3;fontStyle=0;rounded=1;fillStyle=hatch;glass=0;shadow=0;swimlaneFillColor=#E6E6E6;spacing=2;swimlaneLine=0;" value="У гэтым слупку ўсе (&lt;font color=&quot;#ff0000&quot;&gt;? усе ?&lt;/font&gt;) магчымыя страхі наступстваў высвятлення таго, як дадзеная асобная з&#39;ява ўплывае на асабістыя інтарэсы грамадзяніна." vertex="1">
          <mxGeometry height="360" width="400" x="4160" y="21320" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-11" parent="4sducl9t49WLYDzldoge-13" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін будзе разумець, што адбываецца нешта жудаснае." vertex="1">
          <mxGeometry height="80" width="320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-14" parent="4sducl9t49WLYDzldoge-13" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="З гэтым патрэбна будзе нешта рабіць, а грамадзянін думае, што не зможа нічога зрабіць. Адчуваць уласную &lt;br&gt;бездапаможнасць вельмі жудасна." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="200" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-15" edge="1" parent="1" source="4sducl9t49WLYDzldoge-14" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="4sducl9t49WLYDzldoge-16" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4150" y="21491" as="sourcePoint" />
            <mxPoint x="3950" y="21631" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-16" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontColor=#0000CC;strokeColor=#0000CC;fontStyle=1;fontSize=18;" value="" vertex="1">
          <mxGeometry height="30" width="30" x="4105" y="21485" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-17" edge="1" parent="1" source="4sducl9t49WLYDzldoge-16" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="RNDRSYDRFuZBWHNrruaz-3" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4190" y="21671" as="sourcePoint" />
            <mxPoint x="4125" y="21591" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-18" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Страх няведання таго, што адбываецца на самой справе, цалкам адсутнічае, або значна меншы, чым страх зразумець рэальнае становішча рэчаў." vertex="1">
          <mxGeometry height="120" width="320" x="4160" y="21720" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-19" edge="1" parent="1" source="4sducl9t49WLYDzldoge-18" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="RNDRSYDRFuZBWHNrruaz-3" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4095" y="21551" as="sourcePoint" />
            <mxPoint x="3950" y="21571" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-20" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="3960" y="21560" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-23" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=#FF0000;" value="Моцная ўстаноўка з дзяцінства. Прыкладна такая: &quot;думаць/клапаціцца пра сябе&quot; == &quot;быць эгаістам&quot;, а &quot;быць эгаістам дрэнна&quot;." vertex="1">
          <mxGeometry height="120" width="320" x="4160" y="22280" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-24" edge="1" parent="1" source="4sducl9t49WLYDzldoge-23" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="JhPQRlO-KKgyaNoFn7eW-11" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4150" y="22051" as="sourcePoint" />
            <mxPoint x="3950" y="22111" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-26" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=#FF0000;" value="&quot;Я - апошняя літара ў алфавіце&quot; вучылі ў школе." vertex="1">
          <mxGeometry height="80" width="320" x="4640" y="22480" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-27" edge="1" parent="1" source="4sducl9t49WLYDzldoge-26" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="4sducl9t49WLYDzldoge-23" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4150" y="22051" as="sourcePoint" />
            <mxPoint x="3950" y="21951" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-28" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=#FF0000;" value="&quot;Акрамя цябе ёсць іншыя людзі. Ты пра іх зусім не думаеш - ты дрэнны.&quot; казалі ў сям&#39;і." vertex="1">
          <mxGeometry height="80" width="320" x="4640" y="22360" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-29" edge="1" parent="1" source="4sducl9t49WLYDzldoge-28" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="4sducl9t49WLYDzldoge-23" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4630" y="22171" as="sourcePoint" />
            <mxPoint x="4470" y="22191" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-30" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=#FF0000;" value="&quot;Я для цябе начамі не спаў/не спала, на працы цяжка надрываўся/надрывалася. А ты нават крышачку падумаць пра мяне не жадаеш. Ты дрэнны.&quot; казалі ў сям&#39;і." vertex="1">
          <mxGeometry height="120" width="320" x="4640" y="22200" as="geometry" />
        </mxCell>
        <mxCell id="4sducl9t49WLYDzldoge-31" edge="1" parent="1" source="4sducl9t49WLYDzldoge-30" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="4sducl9t49WLYDzldoge-23" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="4630" y="22251" as="sourcePoint" />
            <mxPoint x="4470" y="22191" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="qgJFmqJG-6sJmBy31DOs-3" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Самы першы досвед сутыкнення з эмацыйным &quot;болем&quot; ад учынкаў іншых людзей для грамадзяніна здарыўся ў кантакце з вельмі значнымі людзьмі — бацькамі. Потым з настаўнікамі і сябрамі.&lt;br&gt;&lt;br&gt;Гэтыя людзі часта папракалі за тое, што грамадзянін заўважаў свой эмацыйны боль у нязручны для іх момант і рэагаваў на яго нязручным для іх чынам. Значныя людзі грамадзяніна тлумачылі яму, што гэта няважна, што гэта патрэбна ігнараваць. А не тое — грамадзяніна не будуць любіць, не будуць з ім сябраваць." vertex="1">
          <mxGeometry height="280" width="320" x="6840" y="25320" as="geometry" />
        </mxCell>
        <mxCell id="WbGDOdR-wIxGMsY7HyMC-5" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="4440" y="24060" as="geometry" />
        </mxCell>
        <mxCell id="653N9guY6KzKqRdlZXlQ-6" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Чалавек не можа пераадолець страх сутыкнення сваёй карціны свету з пануючай у грамадстве практыкай. Расказваць пра тое, что ў кожнага ёсць свае ўласныя межы і як можна заўважаць іх парушэнне — сутыкнуцца з грамадскім асуджэннем. Вельмі малы адсотак людзей здольны супрацьстаяць натоўпу. (Чытаць пра экспэрыменты Аша пра &lt;span lang=&quot;be&quot; class=&quot;HwtZe&quot;&gt;меркаванні наваколля і сацыяльны ціск&lt;/span&gt;&lt;span lang=&quot;be&quot; class=&quot;HwtZe&quot;&gt;&lt;/span&gt;)" vertex="1">
          <mxGeometry height="240" width="320" x="5680" y="24240" as="geometry" />
        </mxCell>
        <mxCell id="WbGDOdR-wIxGMsY7HyMC-10" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="4960" y="24360" as="geometry" />
        </mxCell>
        <mxCell id="WbGDOdR-wIxGMsY7HyMC-11" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="4960" y="25880" as="geometry" />
        </mxCell>
        <mxCell id="WbGDOdR-wIxGMsY7HyMC-12" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="4440" y="25581" as="geometry" />
        </mxCell>
