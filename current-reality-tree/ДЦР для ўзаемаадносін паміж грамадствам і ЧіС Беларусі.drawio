        <mxCell id="7yOMyOzH25ERY1u7nGPe-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Для кожнага з разгледжаных спосабаў паспрабаваць змяніць рэальнасць, каб наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;, чалавек не адчувае выгады для сябе ад спробы выкарыстаць гэты спосаб." vertex="1">
          <mxGeometry height="120" width="320" x="9360" y="14360" as="geometry" />
        </mxCell>
        <mxCell id="7yOMyOzH25ERY1u7nGPe-2" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Чалавек не разглядае (і не спрабуе) іншыя спосабы паспрабаваць змяніць рэальнасць, каб наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="120" width="320" x="9360" y="14120" as="geometry" />
        </mxCell>
        <mxCell id="7yOMyOzH25ERY1u7nGPe-3" edge="1" parent="1" source="7yOMyOzH25ERY1u7nGPe-2" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="Iv9Ri6-5YscL8iWF2wej-15" value="">
          <mxGeometry relative="1" as="geometry">
