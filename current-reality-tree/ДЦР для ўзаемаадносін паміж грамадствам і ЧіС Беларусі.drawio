        <mxCell id="dutxO58CQUxg1F99Theb-12" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="або" vertex="1">
