        </mxCell>
        <mxCell id="m0C3pQuXgAReGaeX7E_y-1" parent="ZnFKz9h1lJ7Z8DgdpqAQ-9" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін ведае, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
