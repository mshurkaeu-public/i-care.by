        <mxCell id="BEs8K-WkTOi9_ukTomgo-3" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=#FF0000;" value="Для чалавека не лагічна спрыяць таму, каб іншыя людзі навучыліся надаваць вялікую ўвагу сваім эмоцыям, навучыліся разумець вытокі сваіх эмоцый." vertex="1">
          <mxGeometry height="120" width="320" x="6240" y="21320" as="geometry" />
        </mxCell>
        <mxCell id="BEs8K-WkTOi9_ukTomgo-4" edge="1" parent="1" source="3fLgss1ITQnwHuJ1fyQ3-5" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="BEs8K-WkTOi9_ukTomgo-3" value="">
