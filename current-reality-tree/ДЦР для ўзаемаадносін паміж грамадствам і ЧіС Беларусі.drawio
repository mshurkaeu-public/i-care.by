        </mxCell>
        <mxCell id="BEs8K-WkTOi9_ukTomgo-5" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fontColor=default;" value="Чалавек не жадае разабрацца з тым, як навучыць іншых людзей назіраць за сваімі эмоцыямі і разумець іх вытокі." vertex="1">
          <mxGeometry height="80" width="320" x="8960" y="22040" as="geometry" />
        </mxCell>
        <mxCell id="BEs8K-WkTOi9_ukTomgo-6" edge="1" parent="1" source="BEs8K-WkTOi9_ukTomgo-3" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" target="BEs8K-WkTOi9_ukTomgo-5" value="">
