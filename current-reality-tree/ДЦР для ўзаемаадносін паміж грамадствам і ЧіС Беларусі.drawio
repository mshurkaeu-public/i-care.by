        <mxCell id="ZmQK4ekvP3NQA4aDslbH-1" parent="orpWzriD0-cnV71t46CH-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="Чалавек лічыць сябе часткай таго, што ён называе рэальнасцю." vertex="1">
