        <mxCell id="LkW3DMks9PXvqtajtfYp-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="Або дзякуючы намаганням чалавека або дзякуючы нейкім іншым зменам у рэальнасці, ужо няма перашкод, якія &quot;стаяць&quot; паміж чалавекам і выкананнем ім дзеяння &lt;i&gt;D&lt;/i&gt;. А гэта азначае, што дзеянне выканана. Па азначэнню перашкод, якое я выкарыстоўваю на гэтай схеме." vertex="1">
          <mxGeometry height="160" width="320" x="12720" y="18360" as="geometry" />
        </mxCell>
        <mxCell id="LkW3DMks9PXvqtajtfYp-18" edge="1" parent="1" source="LkW3DMks9PXvqtajtfYp-17" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="dYK0j04YIGh792t1d0iJ-14" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
