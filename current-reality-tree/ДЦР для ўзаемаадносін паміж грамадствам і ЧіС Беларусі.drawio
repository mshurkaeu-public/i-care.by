          </mxGeometry>
        </mxCell>
        <mxCell id="qJVqnyRhxdb_ny6kJOoe-5" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontColor=default;strokeColor=default;fontStyle=1;fontSize=20;verticalAlign=middle;fillColor=#E6E6E6;spacing=0;spacingBottom=4;" value="←" vertex="1">
          <mxGeometry height="30" width="30" x="11920" y="10585" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-1" edge="1" parent="1" source="ihIcnJ9AucMJstNqfzvV-8" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="DaLBtCDJlAUfaqohfwfQ-1" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="3430" y="3530" as="sourcePoint" />
            <mxPoint x="3375" y="3380" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-2" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=#0000FF;rotation=0;fillColor=default;fontColor=#0000FF;" value="Калі чалавек нараджаецца, то ён зусім нічога не ведае пра тое, як уладкаваны свет/рэальнасць. &lt;font color=&quot;#808080&quot;&gt;(базавая гіпотэза 3)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="320" x="3560" y="2720" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-3" parent="1" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;verticalAlign=top;fillColor=#E6E6E6;strokeColor=#B3B3B3;fontStyle=0;rounded=1;fillStyle=hatch;glass=0;shadow=0;swimlaneFillColor=#E6E6E6;spacing=2;swimlaneLine=0;" value="Згодна з базавай гіпотэзай 4, каб жывы і ў прытомнасці грамадзянін не ведаў, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося, неабходна адначасовае выкананне ўсіх прычын з гэтага слупка." vertex="1">
          <mxGeometry height="1320" width="400" x="3520" y="2880" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-4" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Веды, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося, не былі &quot;ўшыты&quot; ў гены грамадзяніна." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-5" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін нават выпадкова не даведаўся ад іншых людзей пра тое, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="880" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-6" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Нават мэтанакіравана не ўклалі ў галаву грамадзяніна іншыя людзі веды пра тое, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="480" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-7" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін не шукаў сам веды сярод існуючых ведаў чалавецтва па тэме блізкай да таго, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося. Або не знайшоў." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="680" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-8" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін не&amp;nbsp;стварыў самастойна веды, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-9" parent="ihIcnJ9AucMJstNqfzvV-3" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Грамадзянін нават неўсвядомлена не скапіраваў паводзіны іншых людзей, каб ведаць, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="280" as="geometry" />
        </mxCell>
        <mxCell id="ihIcnJ9AucMJstNqfzvV-10" edge="1" parent="1" source="ihIcnJ9AucMJstNqfzvV-2" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="DaLBtCDJlAUfaqohfwfQ-1" value="">
