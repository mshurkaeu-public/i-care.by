        <mxCell id="1gqZnxD32R8iCpgrY54I-1" parent="C_di4pAKcFfrG4ThGQaM-1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#0000FF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=stencil();" value="" vertex="1">
