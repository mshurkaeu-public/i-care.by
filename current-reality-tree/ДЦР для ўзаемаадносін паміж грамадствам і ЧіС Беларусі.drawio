        <mxCell id="MPoFinrV3nIF7SRB2cIw-13" parent="w0RshDjsbmjo_j19ezAq-6" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="Эмацыйны стан чалавека." vertex="1">
