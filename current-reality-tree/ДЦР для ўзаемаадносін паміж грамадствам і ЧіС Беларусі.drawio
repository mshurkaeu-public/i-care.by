        <mxCell id="tElrO7AkirXMQkXSnzl--8" parent="tElrO7AkirXMQkXSnzl--5" style="text;html=1;strokeColor=default;fillColor=default;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;flipH=1;fontColor=#FF0000;" value="Усе тыя аспекты жыцця ў грамадстве з наяўнасцю ЧіС, якія ствараюць абставіны для грамадзяніна. (&lt;b&gt;Акрамя&lt;/b&gt; тых аспектаў, дзе абставіны для грамадзяніна стварае &lt;b&gt;непасрэдна ўздзеянне ЧіС на грамадства&lt;/b&gt;.)" vertex="1">
          <mxGeometry height="120" width="320" x="840" y="40" as="geometry" />
        </mxCell>
        <mxCell id="B4Vb4ssWsXtlDbEDd_uy-1" parent="tElrO7AkirXMQkXSnzl--5" style="text;html=1;strokeColor=default;fillColor=default;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;flipH=1;fontColor=#FF0000;" value="Усе &quot;трэція сілы&quot;, якія ствараюць абставіны для грамадзяніна." vertex="1">
