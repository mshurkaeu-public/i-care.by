        <mxCell id="D8lVTSGAFXq-pC_vmSGh-31" connectable="0" parent="D8lVTSGAFXq-pC_vmSGh-30" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelPosition=center;verticalLabelPosition=middle;fontSize=32;fontColor=#FF0000;" value="&lt;div&gt;?&lt;/div&gt;" vertex="1">
