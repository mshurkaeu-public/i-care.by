        <mxCell id="8JEphh9nT4dt-QeBNB_l-4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Павінны быць прычыны, чаму чалавек спрабуе выканаць дзеянне &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="14040" y="17920" as="geometry" />
        </mxCell>
        <mxCell id="8JEphh9nT4dt-QeBNB_l-5" edge="1" parent="1" source="8JEphh9nT4dt-QeBNB_l-4" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="rCBf9kzvDXsQXzaGdKOb-1" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="14005" y="17560" as="sourcePoint" />
