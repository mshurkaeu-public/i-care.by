        <mxCell id="axqSXZxNc-jWN3TFoRUm-5" parent="ALW27m84DgTjXDQXTvm6-1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;div&gt;Нейкія прычыны.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;(&lt;i&gt;Напрыклад, чалавек упэўнены, што калі ён паспрабуе выканаць дзеянне &lt;b&gt;D&lt;/b&gt;, то яго будуць біць &quot;людзі ў чорным&quot;.&lt;/i&gt;)" vertex="1">
