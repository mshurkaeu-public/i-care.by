            <mxPoint x="5120" y="25771" as="sourcePoint" />
            <mxPoint x="4960" y="25691" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="BEr-12BcYO6opY1slGUl-30" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;strokeColor=#0000CC;fontColor=#0000CC;fontStyle=1;" value="3" vertex="1">
          <mxGeometry height="30" width="30" x="3585" y="27145" as="geometry" />
        </mxCell>
        <mxCell id="BEr-12BcYO6opY1slGUl-31" edge="1" parent="1" source="hYxCh7mmWvaN55Y2kegG-25" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="BEr-12BcYO6opY1slGUl-12" value="">
