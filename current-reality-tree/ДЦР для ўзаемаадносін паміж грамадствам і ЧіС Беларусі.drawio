        <mxCell id="BEr-12BcYO6opY1slGUl-20" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="Гэты чалавек кажа грамадзяніну, што можна&amp;nbsp;бараніць свае ўласныя межы або дэманструе гэта сваімі ўласнымі паводзінамі." vertex="1">
          <mxGeometry height="120" width="320" x="4640" y="26281" as="geometry" />
        </mxCell>
