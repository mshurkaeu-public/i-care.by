        <mxCell id="trFHjS8OtI2W3_3FPiBj-24" parent="ZnFKz9h1lJ7Z8DgdpqAQ-9" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;fillColor=default;" value="Грамадзянін не ведае, што дадзенае асобнае ўздзеянне ЧіС на грамадства адбылося." vertex="1">
