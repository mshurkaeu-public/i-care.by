        </mxCell>
        <mxCell id="qJVqnyRhxdb_ny6kJOoe-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="Чалавек усведамляе, што існуюць перашкоды, якія &quot;стаяць&quot; паміж ім і выкананнем дзеяння &lt;i&gt;D&lt;/i&gt;. І ўяўляе набор гэтых перашкод як &lt;b&gt;B&lt;sub&gt;n&lt;/sub&gt;&lt;/b&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="11920" y="10680" as="geometry" />
        </mxCell>
        <mxCell id="qJVqnyRhxdb_ny6kJOoe-8" edge="1" parent="1" source="CkLIY3k917qbzqk4uZhb-14" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;edgeStyle=orthogonalEdgeStyle;curved=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="qJVqnyRhxdb_ny6kJOoe-5" value="">
