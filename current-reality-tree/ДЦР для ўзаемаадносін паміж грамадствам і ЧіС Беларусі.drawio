        <mxCell id="tk5WOwLA9axP-WCMLZNb-1" parent="pBpeqOAFegXsOUu0fZlh-1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontColor=#0000CC;strokeColor=#0000CC;fontStyle=1;fontSize=18;" value="" vertex="1">
