        <mxCell id="3fLgss1ITQnwHuJ1fyQ3-16" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontColor=#0000CC;strokeColor=#0000CC;fontStyle=1;fontSize=18;fillColor=default;" value="" vertex="1">
