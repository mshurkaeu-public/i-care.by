        <mxCell id="ldXz97pExd0vIs4ahGmb-9" parent="ldXz97pExd0vIs4ahGmb-1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="Не адбываецца іншых працэсаў, якія змяняюць колькасць яблыкаў у кошыку." vertex="1">
