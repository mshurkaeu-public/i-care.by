        <mxCell id="BJcEn0zL77pIYxWyM-6r-1" parent="1" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;verticalAlign=top;fillColor=#E6E6E6;strokeColor=#B3B3B3;fontStyle=0;rounded=1;fillStyle=cross-hatch;glass=0;shadow=0;swimlaneFillColor=#E6E6E6;spacing=2;swimlaneLine=0;" value="Згодна з базавай гіпотэзай 2, усе магчымыя прычыны чаму жывы і ў прытомнасці грамадзянін не спрабуе высветліць, як дадзенае асобнае ўздзеянне ЧіС на грамадства ўплывае на яго асабістыя інтарэсы." vertex="1">
          <mxGeometry height="2280" width="400" x="3040" y="20400" as="geometry">
            <mxRectangle height="50" width="970" x="-1640" y="1440" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sWhszSgmb0RcljNFikNW-1" parent="BJcEn0zL77pIYxWyM-6r-1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;b&gt;Грамадзянін не ведае&lt;/b&gt;, што можна/патрэбна спрабаваць высветліць, як асобнае ўздзеянне ЧіС на грамадства ўплывае на яго асабістыя інтарэсы." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ZGO1qrQpXi79sG8c-zsR-1" parent="BJcEn0zL77pIYxWyM-6r-1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;fillColor=default;" value="&lt;b&gt;Грамадзянін&lt;/b&gt; ведае, што можна/патрэбна спрабаваць высветліць, як асобнае ўздзеянне ЧіС на грамадства ўплывае на яго асабістыя інтарэсы, але &lt;b&gt;не мае матывацыі&lt;/b&gt; гэта рабіць." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="Z-fySZ9CyFiNbup-F0ZK-2" parent="BJcEn0zL77pIYxWyM-6r-1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;b&gt;Грамадзянін&lt;/b&gt; ведае, што можна/патрэбна спрабаваць высветліць, як асобнае ўздзеянне ЧіС на грамадства ўплывае на яго асабістыя інтарэсы, жадае гэта рабіць, але &lt;b&gt;не можа&lt;/b&gt; гэта рабіць." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="JhPQRlO-KKgyaNoFn7eW-7" parent="1" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;verticalAlign=top;fillColor=#E6E6E6;strokeColor=#B3B3B3;fontStyle=0;rounded=1;fillStyle=zigzag-line;glass=0;shadow=0;swimlaneFillColor=#E6E6E6;spacing=2;swimlaneLine=0;" value="Згодна з базавай гіпотэзай 2, усе магчымыя прычыны чаму жывы і ў прытомнасці грамадзянін не стварае самастойна веды пра дадзенае асобнае ўздзеянне ЧіС на грамадства" vertex="1">
          <mxGeometry height="7960" width="400" x="4640" y="1480" as="geometry">
            <mxRectangle height="30" width="900" x="-1280" y="1480" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="TJLECN_oBxhWEtQTq3mC-1" parent="JhPQRlO-KKgyaNoFn7eW-7" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;b&gt;Грамадзянін не ведае&lt;/b&gt;, што можна/патрэбна самастойна ствараць веды пра дадзенае асобнае ўздзеянне ЧіС на грамадства.&lt;br&gt; " vertex="1">
          <mxGeometry height="120" width="320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="H2adwTTagYGTjLZC20fY-1" parent="JhPQRlO-KKgyaNoFn7eW-7" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;b&gt;Грамадзянін&lt;/b&gt; ведае, што можна/патрэбна самастойна ствараць веды пра дадзенае асобнае ўздзеянне ЧіС на грамадства, але &lt;b&gt;не мае матывацыі&lt;/b&gt; гэта рабіць.&lt;br&gt; " vertex="1">
          <mxGeometry height="120" width="320" x="40" y="2800" as="geometry" />
        </mxCell>
        <mxCell id="o80giRriBsHeoGOEMKfS-1" parent="JhPQRlO-KKgyaNoFn7eW-7" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;b&gt;Грамадзянін&lt;/b&gt; ведае, што можна/патрэбна самастойна ствараць веды пра дадзенае асобнае ўздзеянне ЧіС на грамадства, мае матывацыю гэта рабіць, але &lt;b&gt;не можа&lt;/b&gt; гэта рабіць.&lt;br&gt; " vertex="1">
          <mxGeometry height="120" width="320" x="40" y="7800" as="geometry" />
        </mxCell>
        <mxCell id="kJyxvsDuKLN6N7F3R-1t-2" edge="1" parent="1" source="kJyxvsDuKLN6N7F3R-1t-1" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="rDFPRCxpqnslvNz2Lett-1" value="">
