        <mxCell id="hAQigQGxuxCvUTN7VuZu-1" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=18;strokeColor=#0000CC;fontColor=#0000CC;fontStyle=1;" value="3" vertex="1">
