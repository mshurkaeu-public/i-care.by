        <mxCell id="qBF6QucXlYF5Fqt-f1LR-3" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="120" width="80" x="4440" y="26481" as="geometry" />
        </mxCell>
        <mxCell id="khyRWcK5IgjRKIxvOn3C-2" parent="1" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;verticalAlign=top;fillColor=#E6E6E6;strokeColor=#B3B3B3;fontStyle=0;rounded=1;fillStyle=hatch;glass=0;shadow=0;swimlaneFillColor=#E6E6E6;spacing=2;swimlaneLine=0;" value="Згодна з базавай гіпотэзай 2, усе магчымыя прычыны чаму жывы і ў прытомнасці чалавек, які ведае, што можна бараніць свае ўласныя межы, не кажа пра гэта грамадзяніну, які пра гэта не ведае." vertex="1">
          <mxGeometry height="560" width="400" x="5120" y="25480" as="geometry" />
        </mxCell>
        <mxCell id="khyRWcK5IgjRKIxvOn3C-3" parent="khyRWcK5IgjRKIxvOn3C-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;b&gt;Чалавек не ведае&lt;/b&gt;, што можна/патрэбна казаць грамадзяніну, які не ведае, што можна бараніць свае ўласныя межы, пра тое, што можна бараніць уласныя межы." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="khyRWcK5IgjRKIxvOn3C-6" parent="khyRWcK5IgjRKIxvOn3C-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;b&gt;Чалавек&lt;/b&gt; ведае, што можна/патрэбна казаць грамадзяніну, які не &lt;br&gt;ведае, што можна бараніць свае ўласныя межы, пра тое, што можна бараніць&lt;br&gt; уласныя межы, але &lt;b&gt;не мае матывацыі&lt;/b&gt; гэта рабіць." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="240" as="geometry" />
        </mxCell>
        <mxCell id="khyRWcK5IgjRKIxvOn3C-5" parent="khyRWcK5IgjRKIxvOn3C-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;b&gt;Чалавек&lt;/b&gt; ведае, што можна/патрэбна казаць грамадзяніну, які не &lt;br&gt;ведае, што можна бараніць свае ўласныя межы, пра тое, што можна бараніць&lt;br&gt; уласныя межы, мае матывацыю гэта рабіць, але &lt;b&gt;не можа&lt;/b&gt; гэта рабіць." vertex="1">
          <mxGeometry height="120" width="320" x="40" y="410" as="geometry" />
        </mxCell>
