          <mxGeometry height="120" width="320" x="40" y="240" as="geometry" />
        </mxCell>
        <mxCell id="eu5MgZHu0a9uYHg2PsV--25" parent="eu5MgZHu0a9uYHg2PsV--22" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&lt;b&gt;Чалавек&lt;/b&gt; ведае, што можна/патрэбна прыняць дастатковыя меры, каб упэўніцца, што перашкоды, якія спыняюць яго адсутнічаюць, мае матывацыю гэта рабіць, але &lt;b&gt;не можа&lt;/b&gt; гэта рабіць." vertex="1">
