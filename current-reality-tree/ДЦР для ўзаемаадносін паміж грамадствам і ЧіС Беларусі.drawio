        <mxCell id="eu5MgZHu0a9uYHg2PsV--23" parent="eu5MgZHu0a9uYHg2PsV--22" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;b&gt;Чалавек не ведае&lt;/b&gt;, што можна/патрэбна прыняць дастатковыя меры, каб упэўніцца, што перашкоды, якія спыняюць яго адсутнічаюць." vertex="1">
