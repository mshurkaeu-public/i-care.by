        <mxCell id="M5lSQ9y89xCI3yr05kLW-4" parent="Ubq82xN2Rb7sQic8AXnV-3" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;glass=0;dashed=1;strokeColor=default;align=left;verticalAlign=middle;arcSize=5;fontFamily=Helvetica;fontSize=16;fontColor=default;fontStyle=0;fillColor=none;gradientColor=none;" value="Вядзе да дакладна вызначанага выніку." vertex="1">
