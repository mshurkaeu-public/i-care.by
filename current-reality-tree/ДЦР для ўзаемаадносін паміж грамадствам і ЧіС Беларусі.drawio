        </mxCell>
        <mxCell id="BEr-12BcYO6opY1slGUl-35" edge="1" parent="1" source="hYxCh7mmWvaN55Y2kegG-25" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="1UCaaAMTz-ETulmOOAEi-1" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="3505" y="24801" as="sourcePoint" />
            <mxPoint x="3400" y="24801" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Павінны быць нейкія прычыны, чаму грамадзянін спрабуе высветліць, як дадзенае асобнае ўздзеянне ЧіС на грамадства ўплывае на яго асабістыя інтарэсы. Але, магчыма, для дадзенага аналізу гэтыя прычыны не істотны." vertex="1">
          <mxGeometry height="160" width="320" x="3080" y="22760" as="geometry" />
        </mxCell>
        <mxCell id="kJyxvsDuKLN6N7F3R-1t-22" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-1" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="trFHjS8OtI2W3_3FPiBj-28" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2110" y="22071" as="sourcePoint" />
            <mxPoint x="2390" y="22471" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;strokeColor=default;fontStyle=0;glass=0;shadow=0;dashed=1;rotation=0;fontColor=#FF0000;" value="Чалавек у адрозненні ад сучаснага кампутара можа ствараць новыя гіпотэзы ў працэсе назірання за наваколлем. За чым такім гэты грамадзянін не назіраў ці назіраў, але без выніка?&lt;br&gt;&lt;br&gt;За самім сабой? За прынцыпамі адносін паміж двума бакамі?" vertex="1">
          <mxGeometry height="160" width="400" x="4160" y="21080" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-7" edge="1" parent="1" source="kJyxvsDuKLN6N7F3R-1t-3" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="AzSIxJlkXMay5v1qxDUT-6" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="3840" y="19961" as="sourcePoint" />
            <mxPoint x="4010" y="19941" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-10" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Павінна быць нейкая прычына, чаму грамадзянін не мае матывацыі бараніць свае ўласныя межы." vertex="1">
          <mxGeometry height="80" width="320" x="3600" y="26520" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-11" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-10" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="1UCaaAMTz-ETulmOOAEi-4" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="3230" y="25031" as="sourcePoint" />
            <mxPoint x="3380" y="25321" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-14" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Напрыклад, чалавек ведае, што гэта тэарэтычна магчыма, але сам не меў пазітыўнага досведу ў гэтым." vertex="1">
          <mxGeometry height="80" width="320" x="5200" y="20120" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-15" edge="1" parent="1" source="E6Pdcet48CIMthdxIpfv-7" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="xnrBB2Fq_RxJNupQK1go-12" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="4350" y="20186" as="sourcePoint" />
            <mxPoint x="4200" y="20096" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-16" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&lt;b&gt;Грамадзянін не ведае пра&lt;/b&gt; тое, што ў яго існуюць свае ўласныя &lt;b&gt;межы&lt;/b&gt;.&lt;br&gt;&lt;br&gt;(Гэта межы, пры парушэнні якіх чалавеку больна/дрэнна.)" vertex="1">
          <mxGeometry height="120" width="320" x="3600" y="24480" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-17" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-16" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="1UCaaAMTz-ETulmOOAEi-1" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="3630" y="24011" as="sourcePoint" />
            <mxPoint x="3525" y="24171" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-18" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=#0000FF;rotation=0;fillColor=default;fontColor=#0000FF;" value="Калі чалавек нараджаецца, то ён зусім нічога не ведае пра тое, як уладкаваны свет/рэальнасць. &lt;font color=&quot;#808080&quot;&gt;(базавая гіпотэза 3)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="320" x="7800" y="22120" as="geometry" />
        </mxCell>
        <mxCell id="13r2Nvp9Kn0BFzEVIfSK-17" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-18" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="13r2Nvp9Kn0BFzEVIfSK-16" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="7790" y="22011" as="sourcePoint" />
            <mxPoint x="7630" y="21651" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-19" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="Адзіны шанец выжыць для маленькага чалавека — цалкам даверыцца людзям вакол яго.&lt;br&gt;&lt;br&gt;Цалкам верыць у тое, што ўсё, што гэтыя людзі робяць і кажуць яму, дапаможа яму выжываць у гэтым свеце." vertex="1">
          <mxGeometry height="160" width="320" x="8120" y="21640" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-21" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;" value="&lt;div&gt;Адсутнасць навыка крытычнага і свядомага асэнсоўвання сацыяльных з&#39;яў і ўласных эмоцый вядзе да таго, што тое, што было &quot;ўкладзена ў галаву&quot; чалавека ў гэтых аспектах ў дзяцінстве, робіцца яго &quot;фундаментам&quot;, на якім будуецца ўся карціна свету ў дарослым жыцці.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="320" x="7080" y="22360" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-25" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-21" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="3fLgss1ITQnwHuJ1fyQ3-16" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="6050" y="21891" as="sourcePoint" />
            <mxPoint x="5890" y="21931" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-22" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Найбольш частая сітуацыя ў беларускім грамадстве — людзі вакол чалавека з самага маленства папракаюць яго за ўважлівасць да сваіх жаданняў і пачуццяў, за громкі плач, за слёзы, папракаюць за недастаткова безумоўнае падпарадкаванне інтарэсам іншых людзей, &quot;мала лі чаго ты жадаеш...&quot;.&lt;br&gt;&lt;br&gt;Не тлумачаць чалавеку, што з ім адбываецца, што гэта эмоцыі, што так яны адчуваюцца. Не вучаць абапірацца на гэтыя сігналы, разумець сябе, разумець ўласныя межы і паведамляць іншым людзям пра парушэнне гэтых межаў экалагічным чынам." vertex="1">
          <mxGeometry height="320" width="320" x="8400" y="22200" as="geometry" />
        </mxCell>
        <mxCell id="qgJFmqJG-6sJmBy31DOs-5" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-16" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="AzSIxJlkXMay5v1qxDUT-22" value="">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="3480" y="24541" />
              <mxPoint x="3480" y="23521" />
              <mxPoint x="8840" y="23521" />
              <mxPoint x="8840" y="22360" />
            </Array>
            <mxPoint x="3590" y="24431" as="sourcePoint" />
            <mxPoint x="5270" y="24011" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-27" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="&lt;div&gt;У сям&#39;і, у дзіцячым садку, у школе, ва універсітэце, на працы &lt;b&gt;не&lt;/b&gt; вучаць крытычна ставіцца да існуючых сацыяльных з&#39;яў, да сацыяльнай іерархіі. Нават хутчэй можна сказаць, што прымушаюць завучваць &quot;догмы&quot; і не задаваць дурных пытанняў. Забаронена &quot;атакаваць&quot; аўтарытэт старэйшага, настаўніка ці начальніка. За &quot;атаку&quot; аўтарытэту бацькоў, настаўнікаў, начальнікаў караюць.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="320" x="7560" y="22360" as="geometry" />
        </mxCell>
        <mxCell id="AzSIxJlkXMay5v1qxDUT-28" edge="1" parent="1" source="AzSIxJlkXMay5v1qxDUT-27" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;elbow=vertical;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;curved=1;" target="AzSIxJlkXMay5v1qxDUT-21" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="6530" y="21951" as="sourcePoint" />
            <mxPoint x="6370" y="21931" as="targetPoint" />
          </mxGeometry>
        </mxCell>
