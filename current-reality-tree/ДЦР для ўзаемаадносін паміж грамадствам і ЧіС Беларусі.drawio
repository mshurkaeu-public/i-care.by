        <mxCell id="khyRWcK5IgjRKIxvOn3C-13" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#BFBFBF;fontSize=16;fontStyle=1" value="і" vertex="1">
          <mxGeometry height="80" width="120" x="-2065" y="10840" as="geometry" />
        </mxCell>
        <mxCell id="khyRWcK5IgjRKIxvOn3C-15" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=#FF0000;" value="Чалавек сам стварыў такія веды для сябе, дзякуючы ўласнаму досведу і дзякуючы ўласнай унутранай працы. І таму лічыць, што адзіны спосаб атрымаць такія веды — самастойна зразумець гэта. Не верыць у тое, што гэта можна растлумачыць." vertex="1">
