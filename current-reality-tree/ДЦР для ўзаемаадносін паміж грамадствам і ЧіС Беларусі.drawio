        <mxCell id="BWvP--xFdiFbOViLsY0I-2" parent="1" style="swimlane;whiteSpace=wrap;html=1;rounded=1;shadow=0;glass=0;fillStyle=hatch;strokeColor=#B3B3B3;align=center;verticalAlign=top;spacing=2;arcSize=15;swimlaneFillColor=#E6E6E6;fontFamily=Helvetica;fontSize=14;fontColor=default;fontStyle=0;fillColor=#E6E6E6;gradientColor=none;swimlaneLine=0;" value="Усе (&lt;font color=&quot;#ff0000&quot;&gt;? усе ?&lt;/font&gt;) магчымыя катэгорыі спосабаў паспрабаваць змяніць рэальнасць, каб наблізіцца да выканання дзеяння &lt;i&gt;D&lt;/i&gt;. " vertex="1">
          <mxGeometry height="1520" width="400" x="7680" y="5760" as="geometry" />
        </mxCell>
        <mxCell id="DRyQWL-BYj0j9HK5H5N2-1" parent="BWvP--xFdiFbOViLsY0I-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&quot;Атакуй&quot;. Чалавек спрабуе знішчыць некаторыя з уяўляемых перашкод з набора &lt;b&gt;B&lt;sub&gt;n&lt;/sub&gt;&lt;/b&gt;, каб выканаць дзеянне &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="H-7rTKJW_ZdAzfzo5BA1-1" parent="BWvP--xFdiFbOViLsY0I-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&quot;Атакуй&quot;/&quot;Пазбягай&quot;. Чалавек спрабуе абыйсці некаторыя з уяўляемых перашкод з набора &lt;b&gt;B&lt;sub&gt;n&lt;/sub&gt;&lt;/b&gt;, каб выканаць дзеянне &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="160" width="320" x="40" y="360" as="geometry" />
        </mxCell>
        <mxCell id="HtWALPR_QNtkMw_p7kNT-8" parent="BWvP--xFdiFbOViLsY0I-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&quot;Вывучай&quot;. Чалавек спрабуе зразумець лепей некаторыя з уяўляемых перашкод з набора &lt;b&gt;B&lt;sub&gt;n&lt;/sub&gt;&lt;/b&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="40" y="720" as="geometry" />
        </mxCell>
        <mxCell id="u6YuKmyZ7m1dQE2V3r3c-12" parent="BWvP--xFdiFbOViLsY0I-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&quot;Вывучай&quot;. Чалавек спрабуе зразумець лепей сваё жаданне выканаць дзеянне &lt;i&gt;D&lt;/i&gt;." vertex="1">
          <mxGeometry height="80" width="320" x="40" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="jWfbbmKtMuQBRBBzEXly-2" parent="BWvP--xFdiFbOViLsY0I-2" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&quot;Вывучай&quot;. Чалавек спрабуе зразумець лепей ўласны працэс прыняцця рашэння і што на яго ўплывае." vertex="1">
