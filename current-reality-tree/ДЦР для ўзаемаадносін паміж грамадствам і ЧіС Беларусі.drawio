        <mxCell id="ZtYtP_QoHvOP3Z3n1pDV-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;spacing=2;spacingTop=0;whiteSpace=wrap;overflow=hidden;rounded=0;verticalAlign=top;spacingBottom=0;align=right;labelPosition=center;verticalLabelPosition=middle;fontSize=13;" value="&lt;div&gt;2025-08-15:&lt;br&gt;&lt;b&gt;Я прысвячаю гэтую працу сабе.&lt;br&gt;А таксама тым хвалям, якія здолеюць зразумець наступныя разважанні пра рэальнасць.&lt;/b&gt;&lt;/div&gt;" vertex="1">
