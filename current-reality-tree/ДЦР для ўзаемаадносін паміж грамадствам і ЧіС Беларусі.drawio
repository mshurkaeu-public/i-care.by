        <mxCell id="S3tnbKk8vrlpBnAOCh3i-15" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=16;strokeColor=default;rotation=0;fillColor=default;fontColor=default;" value="&lt;div&gt;Грамадзянін выбраў не бараніць свае межы. Абарона ўласных межаў выглядае немагчымай, бессэнсоўнай. Навучыўся вытрымваць боль ад парушэння ўласных межаў моўчкі.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="320" x="4640" y="26561" as="geometry" />
        </mxCell>
